# Ollama Configuration
OLLAMA_BASE_URL=https://ollama.services.tirescorp.com
OLLAMA_MODEL=qwen2.5-coder:7b
OLLAMA_API_KEY=
OLLAMA_TIMEOUT=120

# MCP Server Configuration
# AWS Billing & Cost Management MCP Server (superset of Cost Explorer)
MCP_SERVER_COMMAND=uvx
MCP_SERVER_ARGS=--python 3.12 awslabs.billing-cost-management-mcp-server@latest

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# CORS Configuration (comma-separated origins, or * for all)
CORS_ORIGINS=*

# Logging Configuration
LOG_LEVEL=INFO

# AWS Configuration (usually inherited from environment)
# AWS_REGION=us-east-1
# AWS_PROFILE=default
