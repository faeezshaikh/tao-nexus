# Ollama Configuration
OLLAMA_BASE_URL=https://ollama.services.tirescorp.com
OLLAMA_MODEL=qwen2.5-coder:7b
OLLAMA_API_KEY=
OLLAMA_TIMEOUT=120

# MCP Server Configuration
# AWS Billing & Cost Management MCP Server (superset of Cost Explorer)
#MCP_SERVER_COMMAND=c:\Users\721323adm\tao-nexus\agent\.venv\Scripts\python.exe
#MCP_SERVER_ARGS=-m awslabs.cost_explorer_mcp_server.server

MCP_SERVER_COMMAND=uvx
MCP_SERVER_ARGS=awslabs.billing-cost-management-mcp-server@latest

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# CORS Configuration (comma-separated origins, or * for all)
CORS_ORIGINS=*

# Logging Configuration
LOG_LEVEL=INFO

# AWS Configuration
AWS_REGION=us-west-2
# Optional: set this when running outside EC2 with an AWS SSO profile.
# Leave unset on EC2 so boto3 uses the instance profile automatically.
#AWS_PROFILE=DtcBillingReadOnly-307127115570

# Optional: cross-account billing read role. This works with either the
# EC2 instance profile or the AWS_PROFILE credentials above.
AWS_TARGET_ROLE_ARN=arn:aws:iam::307127115570:role/tao-billing-readonly-cross-account-role

# Nexus Configuration
NEXUS_MOCK_MODE=true
